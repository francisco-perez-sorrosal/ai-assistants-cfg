PraxionOrchestration.Orchestrator -> PraxionOrchestration.Pipeline.Promethean: "dispatches"
PraxionOrchestration.Orchestrator -> PraxionOrchestration.Pipeline.Researcher: "dispatches"
PraxionOrchestration.Orchestrator -> PraxionOrchestration.Pipeline.Architect: "dispatches"
PraxionOrchestration.Orchestrator -> PraxionOrchestration.Pipeline.Interface_des: "dispatches"
PraxionOrchestration.Orchestrator -> PraxionOrchestration.Pipeline.Planner: "dispatches"
PraxionOrchestration.Orchestrator -> PraxionOrchestration.Pipeline.Implementer: "dispatches"
PraxionOrchestration.Orchestrator -> PraxionOrchestration.Pipeline.Test_engineer: "dispatches"
PraxionOrchestration.Orchestrator -> PraxionOrchestration.Pipeline.Doc_engineer: "dispatches"
PraxionOrchestration.Orchestrator -> PraxionOrchestration.Pipeline.Verifier: "dispatches"
PraxionOrchestration.Pipeline.Researcher -> PraxionOrchestration.Doc_research: "[...]"
PraxionOrchestration.Doc_research -> PraxionOrchestration.Pipeline.Architect: "[...]"
PraxionOrchestration.Pipeline.Architect -> PraxionOrchestration.Doc_systems: "[...]"
PraxionOrchestration.Doc_systems -> PraxionOrchestration.Pipeline.Planner: "reads"
PraxionOrchestration.Pipeline.Architect -> PraxionOrchestration.Doc_interface: "revises per architect re-eval"
PraxionOrchestration.Pipeline.Interface_des -> PraxionOrchestration.Doc_interface: "writes"
PraxionOrchestration.Doc_interface -> PraxionOrchestration.Pipeline.Architect: "reads challenges"
PraxionOrchestration.Pipeline.Planner -> PraxionOrchestration.Doc_impl_plan: "writes"
PraxionOrchestration.Doc_impl_plan -> PraxionOrchestration.Pipeline.Implementer: "reads"
PraxionOrchestration.Doc_impl_plan -> PraxionOrchestration.Pipeline.Test_engineer: "reads"
PraxionOrchestration.Doc_impl_plan -> PraxionOrchestration.Pipeline.Doc_engineer: "reads"
PraxionOrchestration.Pipeline.Verifier -> PraxionOrchestration.Doc_verify: "writes"
PraxionOrchestration.Pipeline.Verifier -> PraxionOrchestration.Doc_rework: "emits Phase 12.5"
PraxionOrchestration.Doc_rework -> PraxionOrchestration.Orchestrator: "reads manifest"
PraxionOrchestration.Orchestrator -> PraxionOrchestration.Doc_findings: "writes one VERIFIER_FINDINGS.md per \nworktree"
PraxionOrchestration.Doc_findings -> PraxionKnowledge.Commands: "auto-discovered by /resume-rework"
PraxionKnowledge.Commands -> PraxionOrchestration.Pipeline.Architect: "dispatches systems-architect \n(always-first)"
PraxionOrchestration.Pipeline.Architect -> PraxionPersistence.Adrs: "writes ADR fragment when load-bearing"
PraxionOrchestration.Orchestrator -> PraxionPersistence.Tdl: "[...]"
PraxionOrchestration.Pipeline.Verifier -> PraxionPersistence.Tdl: "files row from deferred CIS"
