#!/usr/bin/env bash
# Launch Claude Code with the Praxion working tree as the plugin source.
#
# Use this when developing on Praxion itself. The working-tree copy of the
# i-am plugin shadows any marketplace-installed i-am@bit-agora for this
# session (per Claude Code docs — no uninstall needed). Edits to skills,
# commands, agents, or hooks are live; run /reload-plugins inside the
# session to refresh without relaunching.
#
# By default the launcher also passes --dangerously-skip-permissions,
# because dev loops against your own working tree rarely benefit from
# per-tool prompts and those prompts break the "edit → reload → retry"
# flow. To keep permission prompts enabled (e.g., when testing a hook's
# permission behavior), run with PRAXION_DEV_SAFE=1 in the environment.

set -euo pipefail

# Resolve this script's real path even when invoked through a symlink
# (e.g., via ~/.local/bin/praxion-claude-dev). macOS-safe — avoids GNU
# readlink -f and handles nested symlinks.
self="${BASH_SOURCE[0]}"
while [ -L "$self" ]; do
    dir="$(cd -P "$(dirname "$self")" && pwd)"
    target="$(readlink "$self")"
    [[ "$target" != /* ]] && target="$dir/$target"
    self="$target"
done
praxion_root="$(cd -P "$(dirname "$self")/.." && pwd)"

if [ ! -f "$praxion_root/.claude-plugin/plugin.json" ]; then
    printf "praxion-claude-dev: %s does not look like the Praxion repo root\n" "$praxion_root" >&2
    printf "  (expected %s/.claude-plugin/plugin.json)\n" "$praxion_root" >&2
    exit 1
fi

# Safe mode: caller opted out of --dangerously-skip-permissions.
if [ "${PRAXION_DEV_SAFE:-0}" = "1" ]; then
    exec claude --plugin-dir "$praxion_root" "$@"
fi

# Default: skip per-tool permission prompts during the dev loop.
exec claude --plugin-dir "$praxion_root" --dangerously-skip-permissions "$@"
